# RPC URL for Monad Testnet
RPC_URL=https://testnet-rpc.monad.xyz

# GasGuard contract address on Monad Testnet
CONTRACT_ADDRESS=0x91B96253D6D904f90709C5Ef58F66558455727E4

# Keeper wallet private key (needs MON for gas)
PRIVATE_KEY=

# Comma-separated list of tank owner addresses to monitor
# Example: WATCH_OWNERS=0x1234...,0x5678...
WATCH_OWNERS=

# Poll interval in milliseconds (default: 30000 = 30s)
POLL_INTERVAL_MS=30000

# Gas limit for checkAndRefuelAll transactions
GAS_LIMIT=500000
